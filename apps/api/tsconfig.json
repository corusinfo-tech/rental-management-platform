{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/main.ts",
    "src/app.module.ts",
    "src/config/**/*.ts",
    "src/database/**/*.ts",
    "src/core/**/*.ts",
    "src/identity/**/*.ts",
    "src/organization/**/*.ts",
    "src/health/**/*.ts"
  ]
}
