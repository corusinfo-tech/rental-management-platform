POSTGRES_DB=noagent4u
POSTGRES_USER=noagent4u
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://noagent4u:replace-with-a-long-random-password@postgres:5432/noagent4u?schema=public
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=replace-with-a-unique-random-32-plus-character-secret
JWT_REFRESH_SECRET=replace-with-a-different-random-32-plus-character-secret
JWT_ISSUER=noagent4u-api
JWT_AUDIENCE=noagent4u-web
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
EMAIL_VERIFICATION_TTL_SECONDS=86400
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_REQUEST_IP_LIMIT=5
EMAIL_VERIFICATION_REQUEST_EMAIL_LIMIT=3
EMAIL_VERIFICATION_REQUEST_WINDOW_SECONDS=3600
REGISTRATION_IP_LIMIT=5
REGISTRATION_IDENTIFIER_LIMIT=3
REGISTRATION_THROTTLE_WINDOW_SECONDS=3600
REGISTRATION_BODY_LIMIT_BYTES=16384
REGISTRATION_THROTTLE_HASH_SECRET=replace-with-a-unique-registration-throttle-secret-at-least-32-characters
TRUST_PROXY_HOPS=1
WEB_ORIGIN=https://noagent4u.com
SMTP_URL=smtps://username:password@smtp.example.com:465
NODE_ENV=production
LOG_LEVEL=info
