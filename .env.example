# Secret-free environment template. Copy to .env (local) or .env.production
# (VPS), then replace every REPLACE_WITH_* value through an approved secret
# manager or local developer-only mechanism. Never commit populated files.

# Application
NODE_ENV=development
PORT=3001
WEB_ORIGIN=http://localhost:3000

# JWT
JWT_ACCESS_SECRET=REPLACE_WITH_UNIQUE_32_CHARACTER_MINIMUM_ACCESS_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_UNIQUE_32_CHARACTER_MINIMUM_REFRESH_SECRET
JWT_ISSUER=noagent4u-api
JWT_AUDIENCE=noagent4u-web
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
EMAIL_VERIFICATION_TTL_SECONDS=86400
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_MAX_RESENDS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_REQUEST_IP_LIMIT=5
EMAIL_VERIFICATION_REQUEST_EMAIL_LIMIT=3
EMAIL_VERIFICATION_REQUEST_WINDOW_SECONDS=3600
AUTH_REQUEST_IP_LIMIT=10
AUTH_REQUEST_IDENTIFIER_LIMIT=5
AUTH_REQUEST_WINDOW_SECONDS=60
# Canonical base64 encoding of exactly 32 random bytes.
VERIFICATION_ENCRYPTION_KEY=REPLACE_WITH_CANONICAL_BASE64_32_BYTE_AES256_KEY
VERIFICATION_KEY_VERSION=v1
REGISTRATION_IP_LIMIT=5
REGISTRATION_IDENTIFIER_LIMIT=3
REGISTRATION_THROTTLE_WINDOW_SECONDS=3600
REGISTRATION_BODY_LIMIT_BYTES=16384
REGISTRATION_THROTTLE_HASH_SECRET=REPLACE_WITH_UNIQUE_32_CHARACTER_MINIMUM_THROTTLE_SECRET
TRUST_PROXY_HOPS=1

# PostgreSQL
POSTGRES_DB=noagent4u
POSTGRES_USER=REPLACE_WITH_DATABASE_USER
POSTGRES_PASSWORD=REPLACE_WITH_DATABASE_PASSWORD
POSTGRES_PORT=5432
DATABASE_URL=postgresql://REPLACE_WITH_DATABASE_USER:REPLACE_WITH_DATABASE_PASSWORD@localhost:5432/noagent4u
# Test-only: must name an empty disposable PostgreSQL database.
IDENTITY_TEST_DATABASE_URL=postgresql://REPLACE_WITH_DATABASE_USER:REPLACE_WITH_DATABASE_PASSWORD@localhost:5432/noagent4u_test

# Redis / BullMQ
REDIS_URL=redis://localhost:6379/0
# Test-only: use an isolated disposable Redis DB or namespace.
TEST_REDIS_URL=redis://localhost:6379/15
REDIS_PORT=6379

# pgAdmin
PGADMIN_DEFAULT_EMAIL=REPLACE_WITH_PGADMIN_EMAIL
PGADMIN_DEFAULT_PASSWORD=REPLACE_WITH_PGADMIN_PASSWORD
PGADMIN_PORT=5050

# MinIO
MINIO_ROOT_USER=REPLACE_WITH_MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=REPLACE_WITH_MINIO_ROOT_PASSWORD
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# SMTP provider (Mailpit does not require credentials by default)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM=no-reply@noagent4u.local
SMTP_REPLY_TO=support@noagent4u.local

# Runtime worker
WORKER_HEALTH_HOST=0.0.0.0
WORKER_HEALTH_PORT=3011
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_LEASE_TIMEOUT_MS=30000
OUTBOX_MAX_ATTEMPTS=8
OUTBOX_RETRY_BASE_DELAY_MS=1000
OUTBOX_BATCH_SIZE=20
