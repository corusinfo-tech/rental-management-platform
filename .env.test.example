# Disposable local/CI test configuration only. Never use these values for a
# development, staging, or production database.

NODE_ENV=test
PORT=3001

POSTGRES_DB=noagent4u_test
POSTGRES_USER=noagent4u_test
POSTGRES_PASSWORD=replace-with-test-only-password
TEST_POSTGRES_PORT=55432
DATABASE_URL=postgresql://noagent4u_test:replace-with-test-only-password@127.0.0.1:55432/noagent4u_test
IDENTITY_TEST_DATABASE_URL=postgresql://noagent4u_test:replace-with-test-only-password@127.0.0.1:55432/noagent4u_test

REDIS_URL=redis://127.0.0.1:56379/15
TEST_REDIS_URL=redis://127.0.0.1:56379/15
TEST_REDIS_PORT=56379

JWT_ACCESS_SECRET=replace-with-test-only-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-different-test-refresh-secret-at-least-32-characters
JWT_ISSUER=noagent4u-test-api
JWT_AUDIENCE=noagent4u-test-web
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

EMAIL_VERIFICATION_TTL_SECONDS=86400
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_MAX_RESENDS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_REQUEST_IP_LIMIT=5
EMAIL_VERIFICATION_REQUEST_EMAIL_LIMIT=3
EMAIL_VERIFICATION_REQUEST_WINDOW_SECONDS=3600
AUTH_REQUEST_IP_LIMIT=10
AUTH_REQUEST_IDENTIFIER_LIMIT=5
AUTH_REQUEST_WINDOW_SECONDS=60
REGISTRATION_IP_LIMIT=5
REGISTRATION_IDENTIFIER_LIMIT=3
REGISTRATION_THROTTLE_WINDOW_SECONDS=3600
REGISTRATION_BODY_LIMIT_BYTES=16384
REGISTRATION_THROTTLE_HASH_SECRET=replace-with-test-only-throttle-secret-at-least-32-characters
VERIFICATION_ENCRYPTION_KEY=replace-with-canonical-base64-encoding-of-exactly-32-test-bytes
VERIFICATION_KEY_VERSION=test-v1
TRUST_PROXY_HOPS=0

TEST_MAILPIT_SMTP_PORT=11025
TEST_MAILPIT_UI_PORT=18025
TEST_MINIO_API_PORT=19000
TEST_MINIO_CONSOLE_PORT=19001
TEST_API_PORT=13001
TEST_WORKER_HEALTH_PORT=13011

SMTP_HOST=127.0.0.1
SMTP_PORT=11025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM=no-reply@noagent4u.test
SMTP_REPLY_TO=support@noagent4u.test

WORKER_HEALTH_HOST=0.0.0.0
WORKER_HEALTH_PORT=3011
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_LEASE_TIMEOUT_MS=30000
OUTBOX_MAX_ATTEMPTS=8
OUTBOX_RETRY_BASE_DELAY_MS=1000
OUTBOX_BATCH_SIZE=20
