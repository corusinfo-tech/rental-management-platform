{
  "name": "noagent4u",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify": "bash scripts/verify.sh",
    "migrate": "prisma migrate deploy --schema prisma/schemas",
    "seed": "prisma db seed --schema prisma/schemas",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "clean": "turbo run clean && find . -name node_modules -type d -prune -exec rm -rf {} +"
  },
  "devDependencies": {
    "@prisma/client": "^6.1.0",
    "eslint": "^8.57.1",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
